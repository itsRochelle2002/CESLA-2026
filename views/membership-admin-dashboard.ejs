      async function submitTransaction() {
        const memberId = document.getElementById("txnMemberId").value;
        const category = document.getElementById("txnCategory").value;
        const date = document.getElementById("txnDate").value;
        const amount = document.getElementById("txnAmount").value;
        if (!memberId || !category || !date || !amount) {
          showToast("Please fill all required fields.");
          return;
        }
        const [table, type] = category.split("-");
        try {
          const res = await fetch(`/membership/admin/add-${table}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              member_id: memberId,
              transaction_date: date,
              type,
              description: document.getElementById("txnDesc").value,
              amount,
              or_number: document.getElementById("txnOR").value,
            }),
          });
          const data = await res.json();
          if (data.success) {
            showToast(
              `✓ ${table} ${type} saved! Balance: ₱${parseFloat(data.newBalance).toLocaleString("en-PH", { minimumFractionDigits: 2 })}`,
            );
            clearTxnForm();
            loadTxnHistory();
          } else showToast(data.message || "Failed to save transaction.");
        } catch (e) {
          showToast("Server error.");
        }
      }
      function clearTxnForm() {
        ["txnMemberSearch", "txnDate", "txnAmount", "txnOR", "txnDesc"].forEach(
          (id) => (document.getElementById(id).value = ""),
        );
        document.getElementById("txnCategory").value = "";
        document.getElementById("txnMemberId").value = "";
      }
      async function loadTxnHistory() {
        const memberFilter = document.getElementById("txnHistoryFilter").value;
        const typeFilter = document.getElementById("txnTypeFilter").value;
        try {
          const [sharesRes, savingsRes] = await Promise.all([
            fetch("/membership/admin/all-shares"),
            fetch("/membership/admin/all-savings"),
          ]);
          let shares = await sharesRes.json();
          let savings = await savingsRes.json();
          if (memberFilter !== "all") {
            shares = shares.filter((t) => String(t.member_id) === memberFilter);
            savings = savings.filter(
              (t) => String(t.member_id) === memberFilter,
            );
          }
          let combined = [];
          if (typeFilter !== "savings")
            combined = combined.concat(
              shares.map((t) => ({ ...t, table: "shares" })),
            );
          if (typeFilter !== "shares")
            combined = combined.concat(
              savings.map((t) => ({ ...t, table: "savings" })),
            );
          combined.sort(
            (a, b) =>
              new Date(b.transaction_date) - new Date(a.transaction_date),
          );
          const totalShares =
            shares
              .filter((t) => t.type === "deposit")
              .reduce((s, t) => s + parseFloat(t.amount), 0) -
            shares
              .filter((t) => t.type === "withdrawal")
              .reduce((s, t) => s + parseFloat(t.amount), 0);
          const totalSavings =
            savings
              .filter((t) => t.type === "deposit")
              .reduce((s, t) => s + parseFloat(t.amount), 0) -
            savings
              .filter((t) => t.type === "withdrawal")
              .reduce((s, t) => s + parseFloat(t.amount), 0);
          document.getElementById("summaryShares").textContent =
            "₱ " +
            totalShares.toLocaleString("en-PH", { minimumFractionDigits: 2 });
          document.getElementById("summarySavings").textContent =
            "₱ " +
            totalSavings.toLocaleString("en-PH", { minimumFractionDigits: 2 });
          const tbody = document.getElementById("txnHistoryBody");
          if (!combined.length) {
            tbody.innerHTML =
              '<tr><td colspan="7" class="empty-msg">No transactions found.</td></tr>';
            return;
          }
          tbody.innerHTML = combined
            .map((t) => {
              const member = approvedMembers.find((m) => m.id === t.member_id);
              const mName = member ? member.full_name || member.username : "—";
              const isDeposit = t.type === "deposit";
              return `<tr>
            <td style="font-size:0.78em;color:var(--muted)">${new Date(t.transaction_date).toLocaleDateString("en-PH")}</td>
            <td>${mName}</td>
            <td><span class="badge badge-${isDeposit ? "approved" : "rejected"}" style="font-size:0.7em">${t.table.toUpperCase()} ${t.type.toUpperCase()}</span></td>
            <td style="color:var(--muted)">${t.description || "—"}</td>
            <td style="color:var(--muted)">${t.or_number || "—"}</td>
            <td class="${isDeposit ? "amount-deposit" : "amount-withdraw"}">${isDeposit ? "+" : "-"}${fmtP(t.amount)}</td>
            <td style="font-family:'DM Mono',monospace;font-weight:600">${fmtP(t.balance)}</td>
          </tr>`;
            })
            .join("");
        } catch (e) {
          console.error(e);
        }
      }
      function computeMonthly() {
        const amount =
          parseFloat(document.getElementById("loanAmount").value) || 0;
        const interest =
          parseFloat(document.getElementById("loanInterest").value) || 0;
        const term = parseInt(document.getElementById("loanTerm").value) || 0;
        if (amount && term) {
          const total = amount * (1 + interest / 100);
          document.getElementById("loanMonthly").value =
            "₱ " + (total / term).toFixed(2);
        }
      }
      async function submitLoan() {
        const memberId = document.getElementById("loanMemberId").value;
        const type = document.getElementById("loanType").value;
        const amount = document.getElementById("loanAmount").value;
        const term = document.getElementById("loanTerm").value;
        const date = document.getElementById("loanDateReleased").value;
        if (!memberId || !type || !amount || !term || !date) {
          showToast("Please fill all required fields.");
          return;
        }
        try {
          const res = await fetch("/membership/admin/add-loan", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              member_id: memberId,
              loan_type: type,
              amount,
              interest_rate: document.getElementById("loanInterest").value || 0,
              term_months: term,
              date_released: date,
              purpose: document.getElementById("loanPurpose").value,
            }),
          });
          const data = await res.json();
          if (data.success) {
            showToast(`✓ Loan released! No: ${data.loanNo}`);
            clearLoanForm();
            loadLoanRecords();
          } else showToast("Failed to release loan.");
        } catch (e) {
          showToast("Server error.");
        }
      }
      function clearLoanForm() {
        [
          "loanMemberSearch",
          "loanAmount",
          "loanInterest",
          "loanTerm",
          "loanDateReleased",
          "loanPurpose",
          "loanMonthly",
        ].forEach((id) => (document.getElementById(id).value = ""));
        document.getElementById("loanType").value = "";
        document.getElementById("loanMemberId").value = "";
      }
      async function loadLoanRecords() {
        await loadLoanApplications();
      }

      function openPaymentModal(loanId, memberId, loanNo, balance, monthly) {
        document.getElementById("payLoanId").value = loanId;
        document.getElementById("payMemberId").value = memberId;
        document.getElementById("payDate").value = new Date()
          .toISOString()
          .split("T")[0];
        document.getElementById("payAmount").value = monthly || "";
        document.getElementById("payPrincipal").value = "";
        document.getElementById("payInterest").value = "";
        document.getElementById("payOR").value = "";
        document.getElementById("paymentLoanInfo").innerHTML =
          `Loan No: <strong>${loanNo}</strong> &nbsp;|&nbsp; Outstanding: <strong style="color:var(--danger)">${fmtP(balance)}</strong>`;
        document.getElementById("paymentModal").classList.add("active");
      }
      async function submitPayment() {
        const loanId = document.getElementById("payLoanId").value;
        const memberId = document.getElementById("payMemberId").value;
        const date = document.getElementById("payDate").value;
        const amount = document.getElementById("payAmount").value;
        if (!date || !amount) {
          showToast("Please fill required fields.");
          return;
        }
        try {
          const res = await fetch("/membership/admin/add-loan-payment", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              loan_id: loanId,
              member_id: memberId,
              payment_date: date,
              amount_paid: amount,
              principal:
                document.getElementById("payPrincipal").value || amount,
              interest: document.getElementById("payInterest").value || 0,
              or_number: document.getElementById("payOR").value,
            }),
          });
          const data = await res.json();
          if (data.success) {
            showToast("✓ Payment recorded!");
            closeModal("paymentModal");
            loadLoanRecords();
          } else showToast("Failed to record payment.");
        } catch (e) {
          showToast("Server error.");
        }
      }

      function confirmAction(action, index) {
        currentAction = action;
        currentIndex = index;
        const a = applications[index];
        const name = a.full_name || a.username;
        if (action === "approve") {
          document.getElementById("confirmIcon").textContent = "✓";
          document.getElementById("confirmTitle").textContent =
            "Approve Application?";
          document.getElementById("confirmMsg").textContent =
            `Approve membership of "${name}"?`;
          document.getElementById("confirmYesBtn").textContent = "Yes, Approve";
          document.getElementById("confirmYesBtn").className =
            "btn-yes-approve";
        } else {
          document.getElementById("confirmIcon").textContent = "✕";
          document.getElementById("confirmTitle").textContent =
            "Reject Application?";
          document.getElementById("confirmMsg").textContent =
            `Reject application of "${name}"?`;
          document.getElementById("confirmYesBtn").textContent = "Yes, Reject";
          document.getElementById("confirmYesBtn").className = "btn-yes-reject";
        }
        document.getElementById("confirmOverlay").classList.add("active");
      }
      function closeConfirm() {
        document.getElementById("confirmOverlay").classList.remove("active");
      }
      async function executeAction() {
        closeConfirm();
        if (currentIndex === null || !currentAction) return;
        const a = applications[currentIndex];
        const newStatus = currentAction === "approve" ? "approved" : "rejected";
        try {
          const res = await fetch("/membership/admin/update-status", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id: a.id, status: newStatus }),
          });
          const data = await res.json();
          if (data.success) {
            applications[currentIndex].status = newStatus;
            showToast(`✓ Member ${newStatus}!`);
            await loadApplications();
          }
        } catch (e) {
          showToast("Error updating status.");
        }
        currentAction = null;
        currentIndex = null;
      }

      function logout() {
        fetch("/membership/admin/logout", { method: "POST" }).then(() =>
          window.location.replace("/membership/admin"),
        );
      }
      function showToast(msg) {
        const t = document.getElementById("toast");
        t.textContent = msg;
        t.classList.add("show");
        setTimeout(() => t.classList.remove("show"), 3500);
      }

      [
        "appModal",
        "paymentModal",
        "loanTimelineModal",
        "memberDetailModal",
        "verifiedDetailModal",
        "loanFormModal",
      ].forEach((id) => {
        const el = document.getElementById(id);
        if (el)
          el.addEventListener("click", function (e) {
            if (e.target === this) closeModal(id);
          });
      });

      // ── LOAN MONITORING ──
      let allLoanMonitorData = [];
      async function loadLoanMonitoring() {
        try {
          const res = await fetch("/membership/admin/loan-applications");
          allLoanMonitorData = await res.json();
        } catch (e) {
          allLoanMonitorData = [];
        }
        renderLmPending();
        loadApprovedByType();
      }

      function switchLmTab(tab, btn) {
        document
          .querySelectorAll(".lm-tab")
          .forEach((b) => b.classList.remove("active"));
        document
          .querySelectorAll(".lm-panel")
          .forEach((p) => p.classList.remove("active"));
        btn.classList.add("active");
        document.getElementById("lm-" + tab).classList.add("active");
        if (tab === "approved") loadApprovedByType();
      }

      function renderLmPending() {
        const tbody = document.getElementById("lmPendingBody");
        const pending = allLoanMonitorData.filter(
          (l) => l.status === "pending",
        );
        if (!pending.length) {
          tbody.innerHTML =
            '<tr><td colspan="6" class="empty-msg">No pending loan applications.</td></tr>';
          return;
        }
        const typeLabels = {
          regular: "Regular",
          emergency: "Emergency",
          educational: "Educational",
          livelihood: "Livelihood",
          others: "Others",
        };
        tbody.innerHTML = pending
          .map((l) => {
            const name = (l.full_name || "").trim() || "—";
            return `<tr>
          <td style="font-family:'DM Mono',monospace;font-size:0.82em;color:var(--muted)">${l.loan_no}</td>
          <td style="font-weight:500;cursor:pointer;color:var(--accent)" onclick="viewLoanForm(${l.id},'${name.replace(/'/g, "\\'")}'">${name}</td>
          <td style="font-size:0.78em;color:var(--muted)"><span class="live-dot"></span>${fmtDT(l.applied_at || l.created_at)}</td>
          <td><span class="badge badge-pending">${(typeLabels[l.loan_type] || l.loan_type).toUpperCase()}</span></td>
          <td><button class="btn btn-ghost" style="font-size:0.74em" onclick="viewLoanForm(${l.id},'${name.replace(/'/g, "\\'")}')">View</button></td>
          <td><div class="btn-grp">
            <button class="btn btn-success" onclick="lmApproveLoan(${l.id},'active',this)">Approve</button>
            <button class="btn btn-danger" onclick="lmApproveLoan(${l.id},'rejected',this)">Reject</button>
          </div></td>
        </tr>`;
          })
          .join("");
      }

      async function viewLoanForm(loanId, memberName) {
        const modal = document.getElementById("loanFormModal");
        const content = document.getElementById("loanFormContent");
        const actions = document.getElementById("loanFormActions");
        document.querySelector("#loanFormModal h2").textContent =
          `Loan Application — ${memberName}`;
        content.innerHTML =
          '<div style="text-align:center;padding:30px;color:var(--muted)">Loading...</div>';
        actions.innerHTML = "";
        modal.classList.add("active");
        const loan = allLoanMonitorData.find((l) => l.id === loanId);
        if (!loan) {
          content.innerHTML =
            '<p style="color:var(--danger)">Loan not found.</p>';
          return;
        }
        const typeLabels = {
          regular: "Regular Loan",
          emergency: "Emergency Loan",
          educational: "Educational Loan",
          livelihood: "Livelihood Loan",
          others: "Others",
        };
        const totalPayable =
          parseFloat(loan.amount || 0) *
          (1 + parseFloat(loan.interest_rate || 0) / 100);
        const monthly = loan.term_months ? totalPayable / loan.term_months : 0;
        content.innerHTML = `
        <div style="background:rgba(79,142,247,0.08);border:1px solid rgba(79,142,247,0.15);border-radius:10px;padding:16px;margin-bottom:16px;display:flex;align-items:center;gap:14px">
          <img src="/images/CESLA_logo.png" style="width:48px;height:48px;object-fit:contain;border-radius:8px">
          <div>
            <div style="font-weight:700;font-size:0.9em;color:var(--text)">CESLA Multi-Purpose Cooperative</div>
            <div style="color:var(--muted);font-size:0.72em;margin-top:2px">CLIMBS Bldg., National Highway, Bulua, CDO</div>
          </div>
          <div style="margin-left:auto;text-align:right">
            <div style="color:var(--accent);font-weight:700;font-size:0.76em;text-transform:uppercase">Loan Application</div>
            <div style="color:var(--muted);font-size:0.7em;font-family:'DM Mono',monospace">${loan.loan_no}</div>
          </div>
        </div>
        <div class="lf-section">
          <div class="lf-section-title">Applicant Information</div>
          <div class="lf-grid">
            <div class="lf-item"><label>Full Name</label><span>${(loan.full_name || "").trim() || "—"}</span></div>
            <div class="lf-item"><label>User ID</label><span style="font-family:'DM Mono',monospace">${loan.user_id || "—"}</span></div>
            <div class="lf-item"><label>Date Applied</label><span>${fmtDT(loan.applied_at || loan.created_at)}</span></div>
            <div class="lf-item"><label>Status</label><span><span class="badge badge-${loan.status === "active" ? "active" : loan.status === "rejected" ? "rejected" : "pending"}">${(loan.status || "").toUpperCase()}</span></span></div>
          </div>
        </div>
        <div class="lf-section">
          <div class="lf-section-title">Loan Details</div>
          <div class="lf-grid">
            <div class="lf-item"><label>Type of Loan</label><span style="font-weight:700;color:var(--accent)">${typeLabels[loan.loan_type] || loan.loan_type}</span></div>
            <div class="lf-item"><label>Loan Amount</label><span style="font-weight:700;color:var(--success);font-family:'DM Mono',monospace">${fmtP(loan.amount)}</span></div>
            <div class="lf-item"><label>Interest Rate</label><span>${parseFloat(loan.interest_rate || 0).toFixed(2)}% / month</span></div>
            <div class="lf-item"><label>Term</label><span>${loan.term_months} months</span></div>
            <div class="lf-item"><label>Monthly Payment</label><span style="font-family:'DM Mono',monospace">${fmtP(monthly)}</span></div>
            <div class="lf-item"><label>Total Payable</label><span style="font-family:'DM Mono',monospace">${fmtP(totalPayable)}</span></div>
            ${loan.date_released ? `<div class="lf-item"><label>Date Released</label><span>${fmtD(loan.date_released)}</span></div>` : ""}
          </div>
        </div>
        ${loan.purpose ? `<div class="lf-section"><div class="lf-section-title">Purpose</div><div style="background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:8px;padding:12px;font-size:0.84em;color:var(--text);line-height:1.6">${loan.purpose}</div></div>` : ""}
        ${loan.outstanding_balance !== null && loan.status === "active" ? `<div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:10px;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;margin-top:4px"><span style="color:var(--muted);font-weight:600;font-size:0.8em;text-transform:uppercase">Outstanding Balance</span><span style="color:var(--danger);font-weight:800;font-size:1.2em;font-family:'DM Mono',monospace">${fmtP(loan.outstanding_balance)}</span></div>` : ""}`;
        if (loan.status === "pending")
          actions.innerHTML = `<button class="modal-btn-approve" onclick="lmApproveLoan(${loan.id},'active',null);closeModal('loanFormModal')">Approve Loan</button><button class="modal-btn-reject" onclick="lmApproveLoan(${loan.id},'rejected',null);closeModal('loanFormModal')">Reject Loan</button>`;
      }

      async function lmApproveLoan(loanId, newStatus, btn) {
        if (
          !confirm(
            `${newStatus === "active" ? "Approve" : "Reject"} this loan?`,
          )
        )
          return;
        if (btn) {
          btn.disabled = true;
          btn.textContent = "...";
        }
        try {
          const res = await fetch("/membership/admin/loan-status", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              loan_id: loanId,
              status: newStatus,
              date_released:
                newStatus === "active"
                  ? new Date().toISOString().split("T")[0]
                  : null,
            }),
          });
          const data = await res.json();
          if (data.success) {
            showToast(
              newStatus === "active" ? "✓ Loan approved!" : "Loan rejected.",
            );
            await loadLoanMonitoring();
          } else {
            showToast("Failed to update loan.");
            if (btn) {
              btn.disabled = false;
              btn.textContent = newStatus === "active" ? "Approve" : "Reject";
            }
          }
        } catch (e) {
          showToast("Server error.");
          if (btn) btn.disabled = false;
        }
      }

      function loadApprovedByType() {
        const type = document.getElementById("approvedLoanTypeFilter").value;
        let data = allLoanMonitorData.filter((l) => l.status === "active");
        if (type !== "all") data = data.filter((l) => l.loan_type === type);
        const label = document.getElementById("approvedCountLabel");
        if (label)
          label.textContent = `${data.length} record${data.length !== 1 ? "s" : ""} found`;
        const tbody = document.getElementById("lmApprovedBody");
        if (!data.length) {
          tbody.innerHTML =
            '<tr><td colspan="5" class="empty-msg">No approved loans for this type.</td></tr>';
          document.getElementById("paymentDrawer").style.display = "none";
          return;
        }
        const typeLabels = {
          regular: "Regular",
          emergency: "Emergency",
          educational: "Educational",
          livelihood: "Livelihood",
          others: "Others",
        };
        tbody.innerHTML = data
          .map((l) => {
            const name = (l.full_name || "").trim() || "—";
            return `<tr id="lm-row-${l.id}" style="cursor:pointer" onclick="togglePaymentDrawer(${l.id},'${name.replace(/'/g, "\\'")}')">
          <td style="font-weight:600;color:var(--text)">${name}</td>
          <td style="font-family:'DM Mono',monospace;color:var(--success)">${fmtP(l.amount)}</td>
          <td><span class="badge badge-active" style="font-size:0.7em">${(typeLabels[l.loan_type] || l.loan_type).toUpperCase()}</span></td>
          <td style="font-family:'DM Mono',monospace;font-size:0.82em;color:var(--muted)">${l.loan_no}</td>
          <td style="font-family:'DM Mono',monospace;color:var(--danger)">${fmtP(l.outstanding_balance)}</td>
        </tr>`;
          })
          .join("");
      }

      let activeDrawerLoanId = null;
      async function togglePaymentDrawer(loanId, memberName) {
        const drawer = document.getElementById("paymentDrawer");
        if (activeDrawerLoanId === loanId) {
          drawer.style.display = "none";
          activeDrawerLoanId = null;
          document
            .querySelectorAll("#lmApprovedBody tr")
            .forEach((r) => (r.style.background = ""));
          return;
        }
        activeDrawerLoanId = loanId;
        document
          .querySelectorAll("#lmApprovedBody tr")
          .forEach((r) => (r.style.background = ""));
        const activeRow = document.getElementById("lm-row-" + loanId);
        if (activeRow) activeRow.style.background = "rgba(79,142,247,0.06)";
        drawer.style.display = "block";
        drawer.innerHTML = `<div class="payment-drawer"><div style="text-align:center;padding:20px;color:var(--muted)">Loading payment history...</div></div>`;
        try {
          const loanData = allLoanMonitorData.find((l) => l.id === loanId);
          const res = await fetch(
            `/membership/admin/member-loan-timeline/${loanData?.member_id}`,
          );
          const data = await res.json();
          const loan = data.loans?.find((l) => l.id === loanId);
          if (!loan) {
            drawer.innerHTML =
              '<div class="payment-drawer"><p style="color:var(--danger);padding:16px">Could not load payment data.</p></div>';
            return;
          }
          const payments = loan.payments || [];
          const totalPaid = payments.reduce(
            (s, p) => s + parseFloat(p.amount_paid || 0),
            0,
          );
          drawer.innerHTML = `
          <div class="payment-drawer">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px">
              <div style="font-weight:700;font-size:0.88em;color:var(--text)">Payment Transactions — ${memberName} <span style="color:var(--muted);font-family:'DM Mono',monospace;font-size:0.85em">(${loan.loan_no})</span></div>
              <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);border-radius:20px;padding:5px 14px;font-size:0.78em;font-weight:700;color:var(--danger);font-family:'DM Mono',monospace"><span class="live-dot"></span>Balance: ${fmtP(loan.outstanding_balance)}</div>
            </div>
            <div class="drawer-stats">
              <div class="drawer-stat"><label>Loan Amount</label><span class="ds-blue">${fmtP(loan.amount)}</span></div>
              <div class="drawer-stat"><label>Total Paid</label><span class="ds-green">${fmtP(totalPaid)}</span></div>
              <div class="drawer-stat"><label><span class="live-dot"></span>Outstanding</label><span class="ds-red">${fmtP(loan.outstanding_balance)}</span></div>
            </div>
            ${
              payments.length
                ? `
            <div style="overflow-x:auto">
              <table class="txn-table">
                <thead><tr><th>Date</th><th>Amount Paid</th><th>Principal</th><th>Interest</th><th>Remaining Balance</th><th>OR No.</th></tr></thead>
                <tbody>
                  ${payments
                    .map(
                      (p) => `<tr>
                    <td style="font-size:0.78em;color:var(--muted)"><span class="live-dot"></span>${fmtD(p.payment_date)}</td>
                    <td class="amount-deposit">${fmtP(p.amount_paid)}</td>
                    <td style="color:var(--muted)">${fmtP(p.principal)}</td>
                    <td style="color:var(--muted)">${fmtP(p.interest)}</td>
                    <td class="amount-withdraw">${fmtP(p.remaining_balance)}</td>
                    <td style="color:var(--muted)">${p.or_number || "—"}</td>
                  </tr>`,
                    )
                    .join("")}
                </tbody>
              </table>
            </div>`
                : '<div style="text-align:center;padding:20px;color:var(--muted);font-size:0.84em">No payments recorded yet.</div>'
            }
            <div style="margin-top:12px;display:flex;justify-content:flex-end">
              <button class="btn btn-warn" onclick="openPaymentModal(${loan.id},${loan.member_id},'${loan.loan_no}',${loan.outstanding_balance},${loan.monthly_payment || 0})">Record Payment</button>
            </div>
          </div>`;
        } catch (e) {
          drawer.innerHTML =
            '<div class="payment-drawer"><p style="color:var(--danger);padding:16px">Error loading payments.</p></div>';
        }
      }

      setInterval(() => {
        const mon = document.getElementById("panel-monitoring");
        if (mon && mon.classList.contains("active")) loadLoanMonitoring();
      }, 15000);
      setInterval(() => loadApplications(), 30000);
      loadApplications();
    </script>
  </body>
</html>
