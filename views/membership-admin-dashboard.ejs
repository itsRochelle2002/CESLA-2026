      let loanTabFilter = "all";
      async function loadLoanApplications() {
        try {
          const res = await fetch("/membership/admin/loan-applications");
          allLoanApplications = await res.json();
        } catch (e) {
          allLoanApplications = [];
        }
        renderLoanApplications();
      }
      function switchLoanTab(filter, btn) {
        loanTabFilter = filter;
        document
          .querySelectorAll("#panel-loans .inner-tab")
          .forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        renderLoanApplications();
      }
      function renderLoanApplications() {
        const tbody = document.getElementById("loanApplicationsBody");
        if (!tbody) return;
        let data = allLoanApplications;
        if (loanTabFilter !== "all")
          data = data.filter((l) => l.status === loanTabFilter);
        if (!data.length) {
          tbody.innerHTML = `<tr><td colspan="7" class="empty-msg">No loans found.</td></tr>`;
          return;
        }
        tbody.innerHTML = data
          .map((l) => {
            const name = (l.full_name || "").trim() || "—";
            const appliedAt = l.applied_at || l.created_at;
            const actions = [];
            if (l.status === "pending") {
              actions.push(
                `<button class="btn btn-success" onclick="approveLoan(${l.id},'active')">Approve</button>`,
              );
              actions.push(
                `<button class="btn btn-danger" onclick="approveLoan(${l.id},'rejected')">Reject</button>`,
              );
            }
            actions.push(
              `<button class="btn btn-ghost" onclick="viewLoanTimeline(${l.member_id},'${name}')">Timeline</button>`,
            );
            if (l.status === "active")
              actions.push(
                `<button class="btn btn-warn" onclick="openPaymentModal(${l.id},${l.member_id},'${l.loan_no}',${l.outstanding_balance})">Payment</button>`,
              );
            return `<tr>
          <td style="font-weight:500;cursor:pointer" onclick="viewLoanTimeline(${l.member_id},'${name}')">${name}</td>
          <td style="font-family:'DM Mono',monospace;font-size:0.82em;color:var(--muted)">${l.loan_no}</td>
          <td>${(l.loan_type || "").toUpperCase()}</td>
          <td style="font-family:'DM Mono',monospace">${fmtP(l.amount)}</td>
          <td style="font-size:0.76em;color:var(--muted)">${fmtDT(appliedAt)}</td>
          <td><span class="badge badge-${l.status === "active" ? "active" : l.status === "rejected" ? "rejected" : l.status === "paid" ? "paid" : "pending"}">${(l.status || "").toUpperCase()}</span></td>
          <td><div class="btn-grp">${actions.join("")}</div></td>
        </tr>`;
          })
          .join("");
      }

      async function approveLoan(loanId, newStatus) {
        if (
          !confirm(
            `${newStatus === "active" ? "Approve" : "Reject"} this loan?`,
          )
        )
          return;
        try {
          const res = await fetch("/membership/admin/loan-status", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              loan_id: loanId,
              status: newStatus,
              date_released:
                newStatus === "active"
                  ? new Date().toISOString().split("T")[0]
                  : null,
            }),
          });
          const data = await res.json();
          if (data.success) {
            showToast(
              newStatus === "active" ? "✓ Loan approved!" : "Loan rejected.",
            );
            loadLoanApplications();
          }
        } catch (e) {
          showToast("Server error.");
        }
      }

      async function viewLoanTimeline(memberId, memberName) {
        const modal = document.getElementById("loanTimelineModal");
        const content = document.getElementById("loanTimelineContent");
        document.querySelector("#loanTimelineModal h2").textContent =
          `Loan Timeline — ${memberName}`;
        content.innerHTML =
          '<div style="text-align:center;padding:30px;color:var(--muted)">Loading...</div>';
        modal.classList.add("active");
        try {
          const res = await fetch(
            `/membership/admin/member-loan-timeline/${memberId}`,
          );
          const data = await res.json();
          if (!data.success || !data.loans.length) {
            content.innerHTML =
              '<div style="text-align:center;color:var(--muted);padding:30px">No loan records found.</div>';
            return;
          }
          content.innerHTML = data.loans
            .map((l) => {
              const events = [];
              events.push({
                icon: "◈",
                label: "Loan Applied",
                dt: l.applied_at || l.created_at,
                color: "var(--accent)",
                note: `${(l.loan_type || "").toUpperCase()} — ${fmtP(l.amount)}`,
              });
              if (l.approved_at)
                events.push({
                  icon: "✓",
                  label: "Loan Approved",
                  dt: l.approved_at,
                  color: "var(--success)",
                  note: `Released: ${fmtP(l.amount)}`,
                });
              if (l.rejected_at)
                events.push({
                  icon: "✕",
                  label: "Loan Rejected",
                  dt: l.rejected_at,
                  color: "var(--danger)",
                  note: "",
                });
              (l.payments || []).forEach((p) =>
                events.push({
                  icon: "$",
                  label: "Payment",
                  dt: p.payment_date,
                  color: "var(--warn)",
                  note: `Paid: ${fmtP(p.amount_paid)} | Balance: ${fmtP(p.remaining_balance)}`,
                }),
              );
              events.sort((a, b) => new Date(a.dt) - new Date(b.dt));
              return `<div style="background:rgba(255,255,255,0.02);border:1px solid var(--border);border-radius:10px;padding:14px 16px;margin-bottom:12px">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
              <strong style="font-family:'DM Mono',monospace;color:var(--text)">${l.loan_no}</strong>
              <span class="badge badge-${l.status === "active" ? "active" : l.status === "rejected" ? "rejected" : l.status === "paid" ? "paid" : "pending"}">${l.status.toUpperCase()}</span>
            </div>
            ${events
              .map(
                (ev, idx) => `
              <div style="display:flex;gap:10px;margin-bottom:${idx < events.length - 1 ? "12px" : "0"}">
                <div style="width:16px;height:16px;border-radius:50%;background:${ev.color};display:flex;align-items:center;justify-content:center;font-size:0.55em;font-weight:700;color:#fff;flex-shrink:0;margin-top:2px">${ev.icon}</div>
                <div>
                  <div style="font-weight:600;font-size:0.8em;color:${ev.color}">${ev.label}</div>
                  <div style="font-size:0.72em;color:var(--muted);margin-top:1px">${fmtDT(ev.dt)}</div>
                  ${ev.note ? `<div style="font-size:0.72em;color:var(--muted);margin-top:1px">${ev.note}</div>` : ""}
                </div>
              </div>`,
              )
              .join("")}
          </div>`;
            })
            .join("");
        } catch (e) {
          content.innerHTML = "Error loading timeline.";
        }
      }

