      function switchMdTab(tab, btn) {
        document
          .querySelectorAll(".md-tab")
          .forEach((b) => b.classList.remove("active"));
        document
          .querySelectorAll(".md-panel")
          .forEach((p) => p.classList.remove("active"));
        btn.classList.add("active");
        const panel = document.getElementById("mdTab-" + tab);
        if (panel) panel.classList.add("active");
      }

      function toggleLoanCard(idx) {
        const body = document.getElementById("lc-body-" + idx);
        const arrow = document.getElementById("lc-arrow-" + idx);
        const isOpen = body.style.display === "block";
        body.style.display = isOpen ? "none" : "block";
        if (arrow) arrow.textContent = isOpen ? "▾" : "▴";
      }

      function quickTxnById(memberId, memberName) {
        const idx = applications.findIndex((a) => a.id === memberId);
        if (idx !== -1) quickTxn(idx);
        else showToast("Member not found.");
      }

      // ── LOAN APPLICATIONS ──
