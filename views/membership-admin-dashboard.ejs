<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CESLA Admin Dashboard</title>
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #98bad5;
        --surface: rgba(13, 27, 62, 0.75);
        --panel: rgba(178, 203, 222, 0.45);
        --border: rgba(255, 255, 255, 0.25);
        --accent: #c9a84c;
        --accent2: #e8c87a;
        --success: #22c55e;
        --danger: #ef4444;
        --warn: #f59e0b;
        --text: #011f4b;
        --muted: rgba(1, 31, 75, 0.55);
        --sidebar-w: 220px;
        --topbar-h: 60px;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: "DM Sans", sans-serif;
        background-color: #98bad5;
        background-image:
          radial-gradient(ellipse 80% 60% at 15% 20%, rgba(26, 52, 120, 0.55) 0%, transparent 65%),
          radial-gradient(ellipse 150% 85% at 85% 75%, rgba(13, 27, 62, 0.8) 0%, transparent 65%),
          url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.022'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        background-attachment: fixed;
        color: var(--text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      body::before {
        content: '';
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, #c9a84c, #e8c87a, #c9a84c, transparent);
        z-index: 9999;
        pointer-events: none;
      }

      /* ── TOPBAR ── */
      .topbar {
        height: var(--topbar-h);
        background: rgba(13, 27, 62, 0.7);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-bottom: 1px solid rgba(201, 168, 76, 0.25);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
      }
      .topbar-left {
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .topbar-logo {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, #c9a84c, #e8c87a);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85em;
        color: #fff;
        letter-spacing: -0.5px;
      }
      .topbar-title {
        font-size: 0.95em;
        font-weight: 600;
        color: #ffffff;
      }
      .topbar-right {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .admin-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 8px;
        padding: 6px 12px;
        font-size: 0.8em;
        font-weight: 500;
        color: #ffffff;
      }
      .admin-avatar {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: var(--accent);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.72em;
        font-weight: 700;
        color: #fff;
      }
      .btn-logout {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.25);
        color: #ef4444;
        border-radius: 8px;
        padding: 7px 16px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.78em;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
      }
      .btn-logout:hover {
        background: rgba(239, 68, 68, 0.2);
      }

      /* ── LAYOUT ── */
      .layout {
        display: flex;
        flex: 1;
        margin-top: var(--topbar-h);
        min-height: calc(100vh - var(--topbar-h));
      }

      /* ── SIDEBAR ── */
      .sidebar {
        width: var(--sidebar-w);
        background: rgba(13, 27, 62, 0.65);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-right: 1px solid rgba(201, 168, 76, 0.2);
        position: fixed;
        top: var(--topbar-h);
        left: 0;
        bottom: 0;
        overflow-y: auto;
        padding: 20px 12px;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .nav-section-label {
        font-size: 0.62em;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.35);
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 14px 10px 6px;
      }
      .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.82em;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.6);
        border: none;
        background: none;
        width: 100%;
        text-align: left;
        transition: all 0.15s;
        font-family: "DM Sans", sans-serif;
      }
      .nav-item:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #ffffff;
      }
      .nav-item.active {
        background: rgba(201, 168, 76, 0.18);
        color: #e8c87a;
        font-weight: 600;
      }
      .nav-item.active .nav-icon {
        color: #e8c87a;
      }
      .nav-icon {
        font-size: 1em;
        width: 18px;
        text-align: center;
        flex-shrink: 0;
      }
      .nav-badge {
        margin-left: auto;
        background: var(--danger);
        color: #fff;
        font-size: 0.68em;
        font-weight: 700;
        border-radius: 20px;
        padding: 2px 7px;
        min-width: 18px;
        text-align: center;
      }
      /* Loan sub-items */
      .nav-sub {
        padding-left: 10px;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .nav-subitem {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px 7px 20px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.78em;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.5);
        border: none;
        background: none;
        width: 100%;
        text-align: left;
        transition: all 0.15s;
        font-family: "DM Sans", sans-serif;
        border-left: 2px solid transparent;
      }
      .nav-subitem:hover {
        color: #ffffff;
        background: rgba(255, 255, 255, 0.06);
      }
      .nav-subitem.active {
        color: #e8c87a;
        border-left-color: #c9a84c;
        background: rgba(201, 168, 76, 0.1);
        font-weight: 600;
      }

      /* ── MAIN CONTENT ── */
      .main {
        margin-left: var(--sidebar-w);
        flex: 1;
        padding: 28px;
        overflow-y: auto;
        min-height: calc(100vh - var(--topbar-h));
      }

      /* ── PAGE HEADER ── */
      .page-header {
        margin-bottom: 24px;
      }
      .page-header h1 {
        font-size: 1.35em;
        font-weight: 700;
        color: #011f4b;
      }
      .page-header p {
        font-size: 0.82em;
        color: var(--muted);
        margin-top: 3px;
      }

      /* ── STAT CARDS ── */
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
      }
      .stat-card {
        background: rgba(178, 203, 222, 0.45);
        border: 1.5px solid rgba(255, 255, 255, 0.55);
        border-radius: 12px;
        padding: 20px;
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        box-shadow: 0 4px 24px rgba(1, 31, 75, 0.1), inset 0 1px 0 rgba(255,255,255,0.6);
      }
      .stat-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
      }
      .stat-card.blue::before {
        background: var(--accent);
      }
      .stat-card.gold::before {
        background: var(--accent2);
      }
      .stat-card.green::before {
        background: var(--success);
      }
      .stat-card.red::before {
        background: var(--danger);
      }
      .stat-label {
        font-size: 0.72em;
        font-weight: 600;
        color: var(--muted);
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 10px;
      }
      .stat-num {
        font-size: 2em;
        font-weight: 700;
        color: #011f4b;
        font-family: "DM Mono", monospace;
      }
      .stat-sub {
        font-size: 0.72em;
        color: var(--muted);
        margin-top: 4px;
      }
      .stat-icon {
        position: absolute;
        top: 16px;
        right: 16px;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1em;
      }
      .stat-card.blue .stat-icon {
        background: rgba(79, 142, 247, 0.12);
      }
      .stat-card.gold .stat-icon {
        background: rgba(245, 197, 24, 0.12);
      }
      .stat-card.green .stat-icon {
        background: rgba(34, 197, 94, 0.12);
      }
      .stat-card.red .stat-icon {
        background: rgba(239, 68, 68, 0.12);
      }

      /* ── PANELS ── */
      .panel {
        display: none;
        flex-direction: column;
        gap: 20px;
      }
      .panel.active {
        display: flex;
      }

      /* ── CARD ── */
      .card {
        background: rgba(178, 203, 222, 0.45);
        border: 1.5px solid rgba(255, 255, 255, 0.55);
        border-radius: 12px;
        overflow: hidden;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        box-shadow: 0 4px 24px rgba(1, 31, 75, 0.12), inset 0 1px 0 rgba(255,255,255,0.6);
      }
      .card-head {
        padding: 16px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.3);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
      }
      .card-head h3 {
        font-size: 0.88em;
        font-weight: 600;
        color: #011f4b;
      }
      .card-body {
        padding: 20px;
      }

      /* ── SEARCH BAR ── */
      .search-wrap {
        position: relative;
        flex: 1;
        max-width: 320px;
      }
      .search-wrap input {
        width: 100%;
        background: rgba(255, 255, 255, 0.35);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 8px;
        padding: 8px 12px 8px 34px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.8em;
        font-weight: 500;
        color: #011f4b;
        outline: none;
        transition: border 0.2s;
      }
      .search-wrap input::placeholder {
        color: rgba(1, 31, 75, 0.45);
      }
      .search-wrap input:focus {
        border-color: #c9a84c;
      }
      .search-wrap::before {
        content: "🔍";
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.75em;
      }

      /* ── TABS ── */
      .tab-row {
        display: flex;
        gap: 6px;
        padding: 16px 20px 0;
      }
      .tab {
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        padding: 8px 14px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.78em;
        font-weight: 600;
        color: rgba(1, 31, 75, 0.5);
        cursor: pointer;
        transition: all 0.15s;
      }
      .tab:hover {
        color: #011f4b;
      }
      .tab.active {
        color: #c9a84c;
        border-bottom-color: #c9a84c;
      }

      /* ── TABLE ── */
      .tbl-wrap {
        overflow-x: auto;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.8em;
      }
      thead th {
        padding: 11px 16px;
        text-align: left;
        font-size: 0.72em;
        font-weight: 600;
        color: rgba(1, 31, 75, 0.55);
        letter-spacing: 0.5px;
        text-transform: uppercase;
        border-bottom: 1px solid rgba(1, 31, 75, 0.12);
        background: rgba(255, 255, 255, 0.15);
      }
      tbody td {
        padding: 12px 16px;
        border-bottom: 1px solid rgba(1, 31, 75, 0.1);
        color: #011f4b;
        font-weight: 400;
        vertical-align: middle;
      }
      tbody tr:last-child td {
        border-bottom: none;
      }
      tbody tr:hover td {
        background: rgba(255, 255, 255, 0.03);
      }
      .empty-msg {
        text-align: center;
        padding: 40px;
        color: var(--muted);
        font-size: 0.82em;
      }

      /* ── BADGES ── */
      .badge {
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.72em;
        font-weight: 600;
        letter-spacing: 0.3px;
      }
      .badge-pending {
        background: rgba(245, 158, 11, 0.12);
        color: #f59e0b;
      }
      .badge-approved {
        background: rgba(34, 197, 94, 0.12);
        color: #22c55e;
      }
      .badge-rejected {
        background: rgba(239, 68, 68, 0.12);
        color: #ef4444;
      }
      .badge-active {
        background: rgba(79, 142, 247, 0.12);
        color: #4f8ef7;
      }
      .badge-paid {
        background: rgba(34, 197, 94, 0.12);
        color: #22c55e;
      }

      /* ── BUTTONS ── */
      .btn {
        border: none;
        border-radius: 7px;
        padding: 6px 14px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.76em;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s;
        display: inline-flex;
        align-items: center;
        gap: 5px;
      }
      .btn-primary {
        background: linear-gradient(135deg, #c9a84c, #e8c87a);
        color: #0d1b3e;
      }
      .btn-primary:hover {
        background: linear-gradient(135deg, #b8943a, #d4b466);
      }
      .btn-success {
        background: rgba(34, 197, 94, 0.12);
        color: #22c55e;
        border: 1px solid rgba(34, 197, 94, 0.2);
      }
      .btn-success:hover {
        background: rgba(34, 197, 94, 0.2);
      }
      .btn-danger {
        background: rgba(239, 68, 68, 0.12);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
      }
      .btn-danger:hover {
        background: rgba(239, 68, 68, 0.2);
      }
      .btn-ghost {
        background: rgba(255, 255, 255, 0.3);
        color: #011f4b;
        border: 1px solid rgba(255, 255, 255, 0.5);
      }
      .btn-ghost:hover {
        background: rgba(255, 255, 255, 0.5);
      }
      .btn-warn {
        background: rgba(245, 197, 24, 0.12);
        color: var(--accent2);
        border: 1px solid rgba(245, 197, 24, 0.2);
      }
      .btn-warn:hover {
        background: rgba(245, 197, 24, 0.2);
      }
      .btn-grp {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
      }

      /* ── INNER PANELS ── */
      .inner-panel {
        display: none;
      }
      .inner-panel.active {
        display: block;
      }

      /* ── ACTIVITY FEED ── */
      .activity-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.8em;
      }
      .activity-item:last-child {
        border-bottom: none;
      }
      .activity-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-top: 4px;
        flex-shrink: 0;
      }
      .dot-blue {
        background: var(--accent);
      }
      .dot-green {
        background: var(--success);
      }
      .dot-red {
        background: var(--danger);
      }
      .dot-gold {
        background: var(--accent2);
      }
      .activity-text {
        color: #011f4b;
        line-height: 1.5;
      }
      .activity-time {
        color: rgba(1, 31, 75, 0.5);
        font-size: 0.85em;
        margin-top: 2px;
      }

      /* ── MEMBERS GRID ── */
      .member-row-sub {
        background: rgba(255, 255, 255, 0.2);
        border-left: 3px solid #c9a84c;
        padding: 16px 20px;
        animation: slideDown2 0.2s ease;
      }
      @keyframes slideDown2 {
        from {
          opacity: 0;
          transform: translateY(-6px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* ── LOAN MONITORING ── */
      .lm-tabs {
        display: flex;
        gap: 0;
        border-bottom: 1px solid var(--border);
      }
      .lm-tab {
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        padding: 12px 20px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.8em;
        font-weight: 600;
        color: rgba(1, 31, 75, 0.5);
        cursor: pointer;
        transition: all 0.15s;
        margin-bottom: -1px;
      }
      .lm-tab:hover {
        color: #011f4b;
      }
      .lm-tab.active {
        color: #c9a84c;
        border-bottom-color: #c9a84c;
      }
      .lm-panel {
        display: none;
        padding: 20px;
      }
      .lm-panel.active {
        display: block;
      }

      /* Loan type select */
      .loan-filter-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        flex-wrap: wrap;
      }
      .styled-select {
        background: rgba(255, 255, 255, 0.35);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 8px;
        padding: 8px 14px;
        color: #011f4b;
        font-family: "DM Sans", sans-serif;
        font-size: 0.8em;
        font-weight: 500;
        outline: none;
        cursor: pointer;
      }
      .styled-select option {
        background: #d4e4f0;
        color: #011f4b;
      }

      /* Payment drawer */
      .payment-drawer {
        background: rgba(255, 255, 255, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.35);
        border-top: none;
        padding: 20px;
        animation: slideDown2 0.2s ease;
      }
      .drawer-stats {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
        flex-wrap: wrap;
      }
      .drawer-stat {
        background: rgba(255, 255, 255, 0.35);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 8px;
        padding: 10px 16px;
        font-size: 0.76em;
      }
      .drawer-stat label {
        display: block;
        color: var(--muted);
        font-weight: 600;
        margin-bottom: 3px;
        letter-spacing: 0.3px;
        text-transform: uppercase;
        font-size: 0.85em;
      }
      .drawer-stat span {
        font-weight: 700;
        font-family: "DM Mono", monospace;
      }
      .ds-blue {
        color: var(--accent);
      }
      .ds-green {
        color: var(--success);
      }
      .ds-red {
        color: var(--danger);
      }
      .live-dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        background: var(--success);
        border-radius: 50%;
        margin-right: 5px;
        animation: pulse 1.4s infinite;
      }
      @keyframes pulse {
        0%,
        100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.4;
          transform: scale(0.8);
        }
      }

      /* ── MODAL ── */
      .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.7);
        z-index: 300;
        align-items: flex-start;
        justify-content: center;
        padding: 20px;
        overflow-y: auto;
        backdrop-filter: blur(4px);
      }
      .modal-overlay.active {
        display: flex;
      }
      .modal-box {
        background: rgba(178, 203, 222, 0.85);
        border: 1.5px solid rgba(255, 255, 255, 0.65);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-radius: 16px;
        width: 100%;
        max-width: 780px;
        padding: 28px 32px;
        box-shadow: 0 24px 64px rgba(1, 31, 75, 0.3);
        animation: popIn 0.2s ease;
        margin: auto;
      }
      @keyframes popIn {
        from {
          opacity: 0;
          transform: scale(0.97);
        }
        to {
          opacity: 1;
          transform: scale(1);
        }
      }
      .modal-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--border);
      }
      .modal-top h2 {
        font-size: 0.95em;
        font-weight: 700;
        color: var(--text);
      }
      .btn-close-modal {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 7px;
        padding: 6px 14px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.76em;
        font-weight: 600;
        cursor: pointer;
      }
      .modal-actions {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-top: 20px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
      }
      .modal-btn-approve {
        background: rgba(34, 197, 94, 0.12);
        color: #22c55e;
        border: 1px solid rgba(34, 197, 94, 0.2);
        border-radius: 8px;
        padding: 10px 28px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.85em;
        font-weight: 700;
        cursor: pointer;
      }
      .modal-btn-reject {
        background: rgba(239, 68, 68, 0.12);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 8px;
        padding: 10px 28px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.85em;
        font-weight: 700;
        cursor: pointer;
      }

      /* Member detail rows */
      .detail-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.82em;
      }
      .detail-row:last-child {
        border-bottom: none;
      }
      .detail-label {
        font-weight: 600;
        color: var(--muted);
        min-width: 140px;
        flex-shrink: 0;
        font-size: 0.9em;
        text-transform: uppercase;
        letter-spacing: 0.3px;
      }

      /* App form inside modal */
      .app-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 14px;
      }
      .app-header img {
        width: 60px;
        height: 60px;
        object-fit: contain;
        border-radius: 8px;
      }
      .app-header-info h3 {
        font-size: 0.95em;
        font-weight: 700;
        color: var(--text);
      }
      .app-header-info p {
        font-size: 0.72em;
        color: var(--muted);
        margin-top: 2px;
      }
      .section-hdr {
        background: rgba(79, 142, 247, 0.08);
        border-left: 3px solid var(--accent);
        font-weight: 700;
        padding: 7px 12px;
        font-size: 0.76em;
        letter-spacing: 0.8px;
        border-radius: 0 6px 6px 0;
        margin: 14px 0 10px;
        color: var(--accent);
        text-transform: uppercase;
      }
      .field-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px 20px;
        font-size: 0.8em;
      }
      .field-item {
        display: flex;
        flex-direction: column;
        gap: 3px;
      }
      .field-item label {
        font-weight: 600;
        color: var(--muted);
        font-size: 0.82em;
      }
      .field-item span {
        font-weight: 500;
        color: var(--text);
        border-bottom: 1px solid var(--border);
        padding-bottom: 3px;
        min-height: 20px;
      }
      .app-form-title {
        text-align: center;
        font-weight: 800;
        text-decoration: underline;
        margin: 10px 0;
        color: var(--text);
        font-size: 0.9em;
      }
      .photo-box-sm {
        width: 60px;
        height: 70px;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.6em;
        color: var(--muted);
        text-align: center;
        font-weight: 600;
        margin-left: auto;
        flex-shrink: 0;
        border-radius: 6px;
      }

      /* Form inputs */
      .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }
      .form-grid.full {
        grid-template-columns: 1fr;
      }
      .form-item {
        display: flex;
        flex-direction: column;
        gap: 5px;
      }
      .form-item.span2 {
        grid-column: 1/-1;
      }
      .form-item label {
        font-size: 0.76em;
        font-weight: 600;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.3px;
      }
      .form-item input,
      .form-item select,
      .form-item textarea {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 9px 12px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.84em;
        font-weight: 500;
        color: var(--text);
        outline: none;
        transition: border 0.2s;
      }
      .form-item input:focus,
      .form-item select:focus,
      .form-item textarea:focus {
        border-color: var(--accent);
      }
      .form-item textarea {
        resize: vertical;
        min-height: 70px;
      }
      .form-item select option {
        background: var(--surface);
      }
      .btn-form-submit {
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 24px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.84em;
        font-weight: 600;
        cursor: pointer;
      }
      .btn-form-cancel {
        background: rgba(255, 255, 255, 0.06);
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 10px 24px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.84em;
        font-weight: 600;
        cursor: pointer;
      }

      /* Member search dropdown */
      .member-search-wrap {
        position: relative;
      }
      .member-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 8px;
        max-height: 200px;
        overflow-y: auto;
        z-index: 100;
        display: none;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
      }
      .member-dropdown.show {
        display: block;
      }
      .member-option {
        padding: 9px 14px;
        font-size: 0.8em;
        font-weight: 500;
        cursor: pointer;
        color: var(--text);
        border-bottom: 1px solid var(--border);
      }
      .member-option:hover {
        background: rgba(79, 142, 247, 0.08);
      }

      /* Txn table */
      .txn-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.78em;
      }
      .txn-table th {
        background: rgba(255, 255, 255, 0.03);
        color: var(--muted);
        padding: 9px 12px;
        text-align: left;
        font-weight: 600;
        font-size: 0.78em;
        letter-spacing: 0.3px;
        text-transform: uppercase;
        border-bottom: 1px solid var(--border);
      }
      .txn-table td {
        padding: 9px 12px;
        border-bottom: 1px solid var(--border);
        color: var(--text);
        font-weight: 400;
      }
      .txn-table tr:last-child td {
        border-bottom: none;
      }
      .amount-deposit {
        color: var(--success);
        font-weight: 700;
        font-family: "DM Mono", monospace;
      }
      .amount-withdraw {
        color: var(--danger);
        font-weight: 700;
        font-family: "DM Mono", monospace;
      }

      /* Loan timeline */
      .timeline-item {
        display: flex;
        gap: 12px;
        margin-bottom: 14px;
      }
      .tl-dot {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        flex-shrink: 0;
        margin-top: 2px;
      }
      .tl-line {
        position: relative;
      }

      /* Balance card */
      .balance-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 16px;
      }
      .balance-card {
        border-radius: 10px;
        padding: 14px 18px;
        border: 1px solid var(--border);
      }
      .balance-card label {
        display: block;
        font-size: 0.68em;
        font-weight: 600;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
      }
      .balance-card .bal-amount {
        font-size: 1.3em;
        font-weight: 700;
        font-family: "DM Mono", monospace;
      }
      .bc-blue {
        background: rgba(79, 142, 247, 0.08);
      }
      .bc-blue .bal-amount {
        color: var(--accent);
      }
      .bc-green {
        background: rgba(34, 197, 94, 0.08);
      }
      .bc-green .bal-amount {
        color: var(--success);
      }
      .bc-red {
        background: rgba(239, 68, 68, 0.08);
      }
      .bc-red .bal-amount {
        color: var(--danger);
      }

      /* Confirm overlay */
      .confirm-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.75);
        z-index: 400;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(4px);
      }
      .confirm-overlay.active {
        display: flex;
      }
      .confirm-card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 28px 24px;
        max-width: 320px;
        width: 90%;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        animation: popIn 0.2s ease;
      }
      .confirm-icon {
        font-size: 2.4em;
      }
      .confirm-card h3 {
        font-size: 0.95em;
        font-weight: 700;
        color: var(--text);
      }
      .confirm-card p {
        font-size: 0.8em;
        color: var(--muted);
        line-height: 1.6;
      }
      .confirm-btns {
        display: flex;
        gap: 10px;
        width: 100%;
      }
      .confirm-btns button {
        flex: 1;
        padding: 10px;
        border: none;
        border-radius: 8px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.82em;
        font-weight: 700;
        cursor: pointer;
      }
      .btn-yes-approve {
        background: var(--success);
        color: #fff;
      }
      .btn-yes-reject {
        background: var(--danger);
        color: #fff;
      }
      .btn-cancel-confirm {
        background: rgba(255, 255, 255, 0.07);
        color: var(--text);
        border: 1px solid var(--border) !important;
      }

      /* Toast */
      .toast {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%) translateY(80px);
        background: var(--panel);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 11px 22px;
        border-radius: 10px;
        font-size: 0.8em;
        font-weight: 600;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
        transition: transform 0.3s ease;
        z-index: 500;
        white-space: nowrap;
      }
      .toast.show {
        transform: translateX(-50%) translateY(0);
      }
      .toast.success {
        border-color: rgba(34, 197, 94, 0.3);
      }
      .toast.error {
        border-color: rgba(239, 68, 68, 0.3);
      }

      /* Lf styles for loan form */
      .lf-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px 20px;
        font-size: 0.8em;
      }
      .lf-item {
        display: flex;
        flex-direction: column;
        gap: 3px;
      }
      .lf-item label {
        font-weight: 600;
        color: var(--muted);
        font-size: 0.82em;
        text-transform: uppercase;
        letter-spacing: 0.3px;
      }
      .lf-item span {
        font-weight: 500;
        color: var(--text);
        border-bottom: 1px solid var(--border);
        padding-bottom: 3px;
        min-height: 20px;
      }
      .lf-section {
        margin-bottom: 16px;
      }
      .lf-section-title {
        font-weight: 700;
        color: var(--text);
        font-size: 0.85em;
        border-bottom: 1px solid var(--border);
        padding-bottom: 8px;
        margin-bottom: 12px;
      }
      /* ── MEMBER DETAIL MODAL ── */
      .md-summary {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 20px;
      }
      .md-card {
        border-radius: 10px;
        padding: 14px 18px;
        border: 1px solid var(--border);
      }
      .md-card label {
        display: block;
        font-size: 0.68em;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
      }
      .md-card .md-val {
        font-size: 1.3em;
        font-weight: 800;
        font-family: "DM Mono", monospace;
      }
      .md-card .md-sub {
        font-size: 0.7em;
        color: var(--muted);
        margin-top: 4px;
      }
      .md-card-green {
        background: rgba(34, 197, 94, 0.08);
        border-color: rgba(34, 197, 94, 0.2);
      }
      .md-card-green .md-val {
        color: #22c55e;
      }
      .md-card-blue {
        background: rgba(79, 142, 247, 0.08);
        border-color: rgba(79, 142, 247, 0.2);
      }
      .md-card-blue .md-val {
        color: #4f8ef7;
      }
      .md-card-red {
        background: rgba(239, 68, 68, 0.08);
        border-color: rgba(239, 68, 68, 0.2);
      }
      .md-card-red .md-val {
        color: #ef4444;
      }

      .md-tabs {
        display: flex;
        border-bottom: 1px solid var(--border);
        margin-bottom: 16px;
      }
      .md-tab {
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        padding: 10px 18px;
        margin-bottom: -1px;
        font-family: "DM Sans", sans-serif;
        font-size: 0.8em;
        font-weight: 700;
        color: var(--muted);
        cursor: pointer;
        transition: all 0.15s;
      }
      .md-tab:hover {
        color: var(--text);
      }
      .md-tab.active {
        color: var(--accent);
        border-bottom-color: var(--accent);
      }
      .md-panel {
        display: none;
      }
      .md-panel.active {
        display: block;
      }

      .md-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.79em;
      }
      .md-table th {
        background: rgba(255, 255, 255, 0.03);
        padding: 9px 12px;
        text-align: left;
        font-weight: 700;
        font-size: 0.75em;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.4px;
        border-bottom: 1px solid var(--border);
      }
      .md-table td {
        padding: 10px 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        color: var(--text);
        vertical-align: middle;
      }
      .md-table tr:last-child td {
        border-bottom: none;
      }
      .md-table tr:hover td {
        background: rgba(255, 255, 255, 0.02);
      }
      .md-empty {
        text-align: center;
        padding: 32px;
        color: var(--muted);
        font-size: 0.82em;
      }
      .td-dep {
        color: #22c55e;
        font-weight: 700;
        font-family: "DM Mono", monospace;
      }
      .td-with {
        color: #ef4444;
        font-weight: 700;
        font-family: "DM Mono", monospace;
      }
      .td-bal {
        font-weight: 700;
        font-family: "DM Mono", monospace;
      }

      .loan-card {
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: 10px;
        overflow: hidden;
      }
      .loan-card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        background: rgba(255, 255, 255, 0.03);
        cursor: pointer;
        transition: background 0.15s;
      }
      .loan-card-head:hover {
        background: rgba(255, 255, 255, 0.06);
      }
      .loan-card-body {
        padding: 16px;
        display: none;
        border-top: 1px solid var(--border);
      }
      .loan-meta {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px 16px;
        margin-bottom: 14px;
        font-size: 0.79em;
      }
      .loan-meta-item label {
        display: block;
        font-size: 0.76em;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        margin-bottom: 2px;
      }
      .loan-meta-item span {
        font-weight: 600;
        color: var(--text);
      }
      .pay-hdr {
        font-size: 0.72em;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
      }
    </style>
  </head>
  <body>
    <!-- TOPBAR -->
    <div class="topbar">
      <div class="topbar-left">
        <button
          onclick="history.back()"
          style="
            background: none;
            border: none;
            color: var(--muted);
            cursor: pointer;
            font-size: 1.1em;
            padding: 4px;
          "
        >
          ←
        </button>
        <div class="topbar-logo">CS</div>
        <span class="topbar-title">CESLA Cooperative</span>
      </div>
      <div class="topbar-right">
        <div class="admin-badge">
          <div class="admin-avatar">A</div>
          Admin <%= adminName %>
        </div>
        <button class="btn-logout" onclick="logout()">Sign Out</button>
      </div>
    </div>

    <div class="layout">
      <!-- SIDEBAR -->
      <aside class="sidebar">
        <div class="nav-section-label">Main</div>
        <button class="nav-item active" onclick="switchTab('dashboard', this)">
          <span class="nav-icon">⊞</span> Dashboard
        </button>

        <div class="nav-section-label">Members</div>
        <button class="nav-item" onclick="switchTab('pending', this)">
          <span class="nav-icon">◈</span> Account Management
          <span class="nav-badge" id="pendingBadge" style="display: none"
            >0</span
          >
        </button>
        <button class="nav-item" onclick="switchTab('members', this)">
          <span class="nav-icon">◉</span> Members Monitoring
        </button>

        <div class="nav-section-label">Loans</div>
        <button
          class="nav-item"
          id="loanParentBtn"
          onclick="toggleLoanNav(this)"
        >
          <span class="nav-icon">◆</span> Loan Management
        </button>
        <div class="nav-sub" id="loanSubNav" style="display: none">
          <button
            class="nav-subitem"
            onclick="switchLoanSub('monitoring', this)"
          >
            Loan Monitoring
          </button>
          <button class="nav-subitem" onclick="switchLoanSub('loans', this)">
            Add Loan
          </button>
        </div>
      </aside>

      <!-- MAIN -->
      <main class="main">
        <!-- ── DASHBOARD ── -->
        <div class="panel active" id="panel-dashboard">
          <div class="page-header">
            <h1>Dashboard Overview</h1>
            <p>
              Welcome back, Admin <%= adminName %>. Here's what's happening
              today.
            </p>
          </div>
          <div class="stats-grid">
            <div class="stat-card blue">
              <div class="stat-icon">⏳</div>
              <div class="stat-label">Pending Accounts</div>
              <div class="stat-num" id="statPending">0</div>
              <div class="stat-sub">Awaiting approval</div>
            </div>
            <div class="stat-card green">
              <div class="stat-icon">✓</div>
              <div class="stat-label">Approved Members</div>
              <div class="stat-num" id="statApproved">0</div>
              <div class="stat-sub">Total verified</div>
            </div>
            <div class="stat-card gold">
              <div class="stat-icon">📋</div>
              <div class="stat-label">App. Forms</div>
              <div class="stat-num" id="statForms">0</div>
              <div class="stat-sub">Submitted forms</div>
            </div>
            <div class="stat-card red">
              <div class="stat-icon">◆</div>
              <div class="stat-label">Active Loans</div>
              <div class="stat-num" id="statActiveLoans">0</div>
              <div class="stat-sub">Ongoing loans</div>
            </div>
          </div>
          <div class="card">
            <div class="card-head">
              <h3>Recent Activity</h3>
              <span style="font-size: 0.72em; color: var(--muted)"
                >Last 30 events</span
              >
            </div>
            <div class="card-body" id="activityFeed">
              <div class="empty-msg">No recent activity.</div>
            </div>
          </div>
        </div>

        <!-- ── ACCOUNT MANAGEMENT ── -->
        <div class="panel" id="panel-pending">
          <div class="page-header">
            <h1>Account Management</h1>
            <p>Review and manage membership registration requests.</p>
          </div>

          <!-- Mini stats -->
          <div
            style="
              display: flex;
              gap: 12px;
              flex-wrap: wrap;
              margin-bottom: 4px;
            "
          >
            <div
              class="stat-card blue"
              style="flex: 1; min-width: 120px; padding: 14px 16px"
            >
              <div class="stat-label">Total</div>
              <div class="stat-num" style="font-size: 1.6em" id="statTotal">
                0
              </div>
            </div>
            <div
              class="stat-card gold"
              style="flex: 1; min-width: 120px; padding: 14px 16px"
            >
              <div class="stat-label">Pending</div>
              <div class="stat-num" style="font-size: 1.6em" id="statPendingAM">
                0
              </div>
            </div>
            <div
              class="stat-card green"
              style="flex: 1; min-width: 120px; padding: 14px 16px"
            >
              <div class="stat-label">Approved</div>
              <div
                class="stat-num"
                style="font-size: 1.6em"
                id="statApprovedAM"
              >
                0
              </div>
            </div>
            <div
              class="stat-card red"
              style="flex: 1; min-width: 120px; padding: 14px 16px"
            >
              <div class="stat-label">Rejected</div>
              <div class="stat-num" style="font-size: 1.6em" id="statRejected">
                0
              </div>
            </div>
          </div>

          <div class="card">
            <div class="tab-row">
              <button
                class="tab active"
                onclick="switchInnerTab('acc-pending', this)"
              >
