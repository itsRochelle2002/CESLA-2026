    <script>
      let applications = [];
      let approvedMembers = [];
      let currentAction = null;
      let currentIndex = null;

      // ── LOAD DATA ──
      async function loadApplications() {
        try {
          const res = await fetch("/membership/admin/data");
          if (res.status === 401) {
            window.location.href = "/membership/admin";
            return;
          }
          applications = await res.json();
          approvedMembers = applications.filter((a) => a.status === "approved");
          populateMemberFilters();
        } catch (e) {
          applications = [];
        }
        renderAll();
      }

      function populateMemberFilters() {
        const opts =
          `<option value="all">All Members</option>` +
          approvedMembers
            .map(
              (m) =>
                `<option value="${m.id}">${m.full_name || m.username}</option>`,
            )
            .join("");
        const txnFilter = document.getElementById("txnHistoryFilter");
        if (txnFilter) txnFilter.innerHTML = opts;
        loadTxnHistory();
      }

      // ── FORMS SEARCH ──
      let allFormsData = [];
      function filterFormsTable() {
        const q = (
          document.getElementById("searchFormInput")?.value || ""
        ).toLowerCase();
        const filtered = allFormsData.filter(
          (a) =>
            (a.full_name || "").toLowerCase().includes(q) ||
            (a.user_id || "").toLowerCase().includes(q),
        );
        renderFormsTableFiltered(filtered);
      }
      function renderFormsTableFiltered(data) {
        const tbody = document.getElementById("formsTableBody");
        if (!data.length) {
          tbody.innerHTML =
            '<tr><td colspan="5" class="empty-msg">No application forms found.</td></tr>';
          return;
        }
        tbody.innerHTML = data
          .map((a) => {
            const ri = applications.indexOf(a);
            const fs = a.form_status || "incomplete";
            const fsBadge = `<span class="badge badge-${fs === "submitted" ? "pending" : fs === "approved" ? "approved" : "rejected"}">${fs.toUpperCase()}</span>`;
            return `<tr>
          <td><span style="font-family:'DM Mono',monospace;font-size:0.88em">${a.user_id || "—"}</span></td>
          <td style="font-weight:500">${(a.full_name || "").trim() || "—"}</td>
          <td style="font-size:0.78em;color:var(--muted)">${fmtDT(a.form_submitted_at)}</td>
          <td>${fsBadge}</td>
          <td><div class="btn-grp">
            <button class="btn btn-ghost" onclick="viewFormModal(${ri})">View Form</button>
            <button class="btn btn-success" onclick="approveForm(${a.id},'approve',${ri})">Approve</button>
            <button class="btn btn-danger" onclick="approveForm(${a.id},'reject',${ri})">Return</button>
          </div></td>
        </tr>`;
          })
          .join("");
      }

      function renderAll() {
        const q = (
          document.getElementById("searchInput")?.value || ""
        ).toLowerCase();
        const filtered = applications.filter(
          (a) =>
            (a.full_name || "").toLowerCase().includes(q) ||
            (a.username || "").toLowerCase().includes(q) ||
            (a.user_id || "").toLowerCase().includes(q),
        );
        const pending = filtered.filter((a) => a.status === "pending");
        const approved = filtered.filter((a) => a.status === "approved");
        const rejected = filtered.filter((a) => a.status === "rejected");
        const formsSubmitted = applications.filter(
          (a) => a.status === "approved" && a.form_status === "submitted",
        );
        const nPending = applications.filter(
          (a) => a.status === "pending",
        ).length;
        const nApproved = applications.filter(
          (a) => a.status === "approved",
        ).length;
        const nRejected = applications.filter(
          (a) => a.status === "rejected",
        ).length;

        const sp = document.getElementById("statPending");
        if (sp) sp.textContent = nPending;
        const sa = document.getElementById("statApproved");
        if (sa) sa.textContent = nApproved;
        const sf = document.getElementById("statForms");
        if (sf) sf.textContent = formsSubmitted.length;

        const st = document.getElementById("statTotal");
        if (st) st.textContent = applications.length;
        const spa = document.getElementById("statPendingAM");
        if (spa) spa.textContent = nPending;
        const saa = document.getElementById("statApprovedAM");
        if (saa) saa.textContent = nApproved;
        const sr = document.getElementById("statRejected");
        if (sr) sr.textContent = nRejected;

        const pb = document.getElementById("pendingBadge");
        if (pb) {
          pb.textContent = nPending;
          pb.style.display = nPending > 0 ? "" : "none";
        }
        const fb = document.getElementById("formsBadge");
        if (fb) fb.textContent = formsSubmitted.length;

        renderActivityHistory();
        renderPendingTable(pending);
        renderApprovedTable(approved);
        renderRejectedTable(rejected);
        renderFormsTable(
          applications.filter(
            (a) => a.status === "approved" && a.form_status === "submitted",
          ),
        );

        // Update active loans stat
        loadLoansStat();
      }

      async function loadLoansStat() {
        try {
