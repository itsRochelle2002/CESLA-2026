<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CESLA Multi-Purpose Cooperative — System Portal</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/global.css" />
    <style>
      :root {
        --navy: #98bad5;
        --gold: #c9a84c;
        --gold-lt: #e8c87a;
        --white: #ffffff;
        --glass: rgba(255,255,255,0.07);
        --glass-border: rgba(255, 255, 255, 0.55);
      }
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: "DM Sans", sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
      }
      header {
        padding: 14px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: transparent;
        animation: slideDown 0.7s ease both;
      }
      @keyframes slideDown {
        from {
          opacity: 0;
          transform: translateY(-20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* ── HEADER LAYOUT ── */
      .header-left {
        display: flex;
        align-items: center;
        gap: 0;
        flex: 1;
        justify-content: flex-start;
      }
      .header-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 1;
        justify-content: flex-end;
      }
      .header-center {
        display: flex;
        align-items: center;
        gap: 50px;
        justify-content: center;
        flex-shrink: 0;
      }
      .header-logo {
        height: 95px;
        width: 95px;
        object-fit: contain;
        border-radius: 50%;
        padding: 3px;
        background: rgba(255, 255, 255, 0.25);
        filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.3));
        flex-shrink: 0;
      }
      .header-title {
        text-align: center;
      }
      .header-title h1 {
        font-family: "Playfair Display", serif;
        font-size: 1.75rem;
        font-weight: 800;
        color: #011f4b;
        letter-spacing: 0.5px;
        line-height: 1.2;
        text-shadow: 0 1px 3px rgba(255, 255, 255, 0.4);
        -webkit-text-stroke: 0.3px #011f4b;
      }
      .header-title h1 span {
        color: #ffffff;
        text-shadow: 0 1px 6px rgba(1, 31, 75, 0.35);
        -webkit-text-stroke: 0.3px rgba(1, 31, 75, 0.3);
      }
      .header-subtitle {
        font-size: 0.72rem;
        color: rgba(3, 57, 108, 0.65);
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-top: 4px;
        font-weight: 400;
      }
      .header-badge {
        background: linear-gradient(135deg, var(--gold), var(--gold-lt));
        color: #0d1b3e;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 5px 14px;
        border-radius: 20px;
        box-shadow: 0 2px 12px rgba(201, 168, 76, 0.4);
        white-space: nowrap;
      }

      main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 52px 40px 40px;
        gap: 48px;
      }
      .section-label {
        text-align: center;
        animation: fadeUp 0.6s 0.3s ease both;
      }
      .section-label h2 {
        font-family: "Playfair Display", serif;
        font-size: 1.1rem;
        font-weight: 800;
        letter-spacing: 6px;
        text-transform: uppercase;
        color: #011f4b;
        text-shadow: 0 1px 8px rgba(1, 31, 75, 0.3);
        -webkit-text-stroke: 0.2px rgba(1, 31, 75, 0.2);
        margin-bottom: 10px;
      }
      .section-label p {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.88);
        font-weight: 400;
        letter-spacing: 0.5px;
        text-shadow: 0 1px 4px rgba(1, 31, 75, 0.2);
      }
      .modules-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
        max-width: 960px;
        width: 100%;
      }
      .module-card {
        position: relative;
        background: var(--glass);
        border: 1.5px solid var(--glass-border);
        border-radius: 20px;
        padding: 44px 28px 36px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 18px;
        cursor: pointer;
        text-decoration: none;
        overflow: hidden;
        transition:
          transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
          box-shadow 0.3s ease,
          border-color 0.3s ease;
        backdrop-filter: blur(14px);
        box-shadow:
          0 4px 24px rgba(1, 31, 75, 0.12),
          inset 0 1px 0 rgba(255, 255, 255, 0.6);
        animation: fadeUp 0.65s ease both;
      }
      .module-card:nth-child(1) {
        animation-delay: 0.15s;
      }
      .module-card:nth-child(2) {
        animation-delay: 0.28s;
      }
      .module-card:nth-child(3) {
        animation-delay: 0.41s;
      }
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .module-card::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 20px;
        background: radial-gradient(
          circle at 50% 0%,
          var(--card-glow, rgba(201, 168, 76, 0.12)) 0%,
          transparent 70%
        );
        opacity: 0;
        transition: opacity 0.4s ease;
      }
      .module-card:hover::before {
        opacity: 1;
      }
      .module-card::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 20%;
        right: 20%;
        height: 2px;
        background: linear-gradient(
          90deg,
          transparent,
          var(--card-accent, var(--gold)),
          transparent
        );
        border-radius: 2px;
        transform: scaleX(0);
        transition: transform 0.4s ease;
      }
      .module-card:hover::after {
        transform: scaleX(1);
      }
      .module-card:hover {
        transform: translateY(-10px) scale(1.02);
        border-color: rgba(255, 255, 255, 0.85);
        box-shadow:
          0 24px 60px rgba(1, 31, 75, 0.2),
          0 0 0 1px rgba(201, 168, 76, 0.2),
          inset 0 1px 0 rgba(255, 255, 255, 0.7);
      }
      .card-coop {
        --card-glow: rgba(42, 90, 200, 0.2);
        --card-accent: #6fa3f7;
      }
      .card-canteen {
        --card-glow: rgba(240, 140, 40, 0.18);
        --card-accent: #f5a623;
      }
      .card-order {
        --card-glow: rgba(201, 168, 76, 0.2);
        --card-accent: var(--gold);
      }
      .card-icon-wrap {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.4rem;
        background: rgba(255, 255, 255, 0.35);
        border: 1px solid rgba(255, 255, 255, 0.6);
        position: relative;
        transition: transform 0.3s ease;
        flex-shrink: 0;
      }
      .module-card:hover .card-icon-wrap {
        transform: scale(1.12) rotate(-4deg);
      }
      .card-icon-ring {
        position: absolute;
        inset: -5px;
        border-radius: 50%;
        border: 1.5px dashed rgba(201, 168, 76, 0.25);
        animation: spinSlow 12s linear infinite;
      }
      @keyframes spinSlow {
        to {
          transform: rotate(360deg);
        }
      }
      .card-name {
        font-family: "Playfair Display", serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: #011f4b;
        letter-spacing: 0.5px;
        line-height: 1.35;
      }
      .card-desc {
        font-size: 0.75rem;
        color: rgba(3, 57, 108, 0.7);
        font-weight: 400;
        line-height: 1.6;
        letter-spacing: 0.3px;
      }
      .card-arrow {
        margin-top: 4px;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.35);
        border: 1px solid rgba(1, 31, 75, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        color: rgba(1, 31, 75, 0.6);
        transition:
          background 0.3s ease,
          color 0.3s ease,
          transform 0.3s ease;
      }
      .module-card:hover .card-arrow {
        background: var(--gold);
        color: #0d1b3e;
        border-color: var(--gold);
        transform: translateX(4px);
      }
      .badge-new {
        position: absolute;
        top: 14px;
        right: 14px;
        background: linear-gradient(135deg, #50c896, #2fa56e);
        color: #fff;
        font-size: 0.55rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 4px 9px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(80, 200, 150, 0.4);
      }
      footer {
        text-align: center;
        padding: 20px 40px 28px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        animation: fadeUp 0.6s 0.6s ease both;
      }
      footer p {
        font-size: 0.72rem;
        color: rgba(235, 239, 242, 0.55);
        letter-spacing: 0.5px;
        font-weight: 400;
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 860px) {
        .modules-grid {
          grid-template-columns: repeat(2, 1fr);
          max-width: 600px;
        }
        .module-card:nth-child(3) {
          grid-column: 1/-1;
          max-width: 280px;
          margin: 0 auto;
        }
        .header-left,
        .header-right {
          display: none;
        }
        .header-center {
          gap: 10px;
        }
        .header-logo {
          height: 44px;
          width: 44px;
        }
        .header-title h1 {
          font-size: 1.2rem;
        }
      }
      @media (max-width: 520px) {
        header {
          padding: 14px 20px;
        }
        .header-title h1 {
          font-size: 1rem;
        }
        .header-badge {
          display: none;
        }
        main {
          padding: 32px 16px 24px;
          gap: 28px;
        }
        .modules-grid {
          grid-template-columns: 1fr;
          max-width: 320px;
          gap: 16px;
        }
        .module-card:nth-child(3) {
          grid-column: auto;
          max-width: 100%;
          margin: 0;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <!-- Left spacer (keeps layout balanced) -->
      <div class="header-left"></div>

      <!-- Center: CESLA logo | Title | CLIMBS logo -->
      <div class="header-center">
        <img
          class="header-logo"
          src="/images/CESLA_logo.png"
          alt="CESLA Logo"
        />
        <div class="header-title">
          <h1>CESLA <span>Multi-Purpose</span> Cooperative</h1>
          <p class="header-subtitle">
            Comprehensive System Portal &nbsp;&bull;&nbsp; Since 1992
          </p>
        </div>
        <img
          class="header-logo"
          src="/images/CLIMBS_Logo.png"
          alt="CLIMBS Logo"
        />
      </div>

      <!-- Right: Portal badge -->
      <div class="header-right">
        <span class="header-badge">Portal v2.0</span>
      </div>
    </header>

    <main>
      <div class="section-label">
        <h2>System Modules</h2>
        <p>Select a service to access its features and tools</p>
      </div>

      <div class="modules-grid">
        <a href="/membership" class="module-card card-coop">
          <div class="card-icon-wrap">
            <span>🏛️</span>
            <div class="card-icon-ring"></div>
          </div>
          <div>
            <div class="card-name">CESLA Multi-Purpose<br />Cooperative</div>
            <div class="card-desc">
              Member registration, shares, savings &amp; loan management
            </div>
          </div>
          <div class="card-arrow">&#8594;</div>
        </a>

        <a href="/ordering" class="module-card card-canteen">
          <div class="card-icon-wrap">
            <span>🍽️</span>
            <div class="card-icon-ring"></div>
          </div>
          <div>
            <div class="card-name">Canteen Management<br />System</div>
            <div class="card-desc">
              Employee food ordering, menu management &amp; daily records
            </div>
          </div>
          <div class="card-arrow">&#8594;</div>
        </a>

        <a href="#" class="module-card card-order">
          <div class="badge-new">New</div>
          <div class="card-icon-wrap">
            <span>📦</span>
            <div class="card-icon-ring"></div>
          </div>
          <div>
            <div class="card-name">Merchandise Ordering<br />System</div>
            <div class="card-desc">
              Place, track &amp; manage merchandise orders with real-time status
            </div>
          </div>
          <div class="card-arrow">&#8594;</div>
        </a>
      </div>
    </main>

    <footer>
      <p>────────────୨ৎ────────────
      </p>
      <p>
        Choose the service you would like to access &nbsp;&bull;&nbsp; CESLA MPC
        &copy; 2025
      </p>
    </footer>
  </body>
</html>
